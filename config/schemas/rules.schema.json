{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://chronobar.local/schemas/rules.schema.json",
  "title": "RulesConfig",
  "type": "object",
  "required": ["rules"],
  "properties": {
    "rules": {
      "type": "object",
      "required": ["calendars", "session_templates"],
      "properties": {
        "calendars": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "type": "object",
            "required": ["timezone", "holiday_source"],
            "properties": {
              "timezone": { "type": "string" },
              "holiday_source": { "type": "string" }
            },
            "additionalProperties": false
          }
        },
        "session_templates": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "type": "object",
            "required": ["exchange", "trading_date_rule", "segments"],
            "properties": {
              "exchange": { "type": "string" },
              "trading_date_rule": { "type": "string" },
              "segments": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "object",
                  "required": ["type", "start", "end"],
                  "properties": {
                    "type": { "type": "string", "enum": ["morning", "afternoon", "night"] },
                    "start": { "type": "string" },
                    "end": { "type": "string" }
                  },
                  "additionalProperties": false
                }
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
