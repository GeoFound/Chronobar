{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://chronobar.local/schemas/system.schema.json",
  "title": "SystemConfig",
  "type": "object",
  "required": ["system"],
  "properties": {
    "system": {
      "type": "object",
      "required": [
        "version",
        "app_name",
        "timezone",
        "log_level",
        "cache_dir",
        "db_url",
        "ui_backend",
        "replay_dir",
        "bridge",
        "ai"
      ],
      "properties": {
        "version": { "type": "string" },
        "app_name": { "type": "string" },
        "timezone": { "type": "string" },
        "log_level": { "type": "string", "enum": ["DEBUG", "INFO", "WARNING", "ERROR"] },
        "cache_dir": { "type": "string" },
        "db_url": { "type": "string" },
        "ui_backend": { "type": "string", "const": "react-desktop" },
        "replay_dir": { "type": "string" },
        "bridge": {
          "type": "object",
          "required": [
            "host",
            "port",
            "query_protocol",
            "command_protocol",
            "subscription_protocol",
            "subscription_port"
          ],
          "properties": {
            "host": { "type": "string" },
            "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
            "query_protocol": { "type": "string", "enum": ["http"] },
            "command_protocol": { "type": "string", "enum": ["http"] },
            "subscription_protocol": { "type": "string", "enum": ["websocket"] },
            "subscription_port": { "type": "integer", "minimum": 1, "maximum": 65535 }
          },
          "additionalProperties": false
        },
        "ai": {
          "type": "object",
          "required": [
            "enabled",
            "model_provider",
            "local_model_path",
            "api_endpoint",
            "api_key",
            "max_tokens",
            "timeout",
            "temperature",
            "features",
            "external_context",
            "memory",
            "apply_policy"
          ],
          "properties": {
            "enabled": { "type": "boolean" },
            "model_provider": {
              "type": "string",
              "enum": ["local", "deepseek", "openai", "anthropic"]
            },
            "local_model_path": { "type": "string" },
            "api_endpoint": { "type": "string" },
            "api_key": { "type": "string" },
            "max_tokens": { "type": "integer", "minimum": 1 },
            "timeout": { "type": "integer", "minimum": 1 },
            "temperature": { "type": "number", "minimum": 0, "maximum": 2 },
            "features": {
              "type": "object",
              "required": [
                "copilot",
                "signal_generation",
                "risk_check",
                "backtest_analysis",
                "auto_tuning",
                "artifact_builder",
                "external_context",
                "memory"
              ],
              "properties": {
                "copilot": { "type": "boolean" },
                "signal_generation": { "type": "boolean" },
                "risk_check": { "type": "boolean" },
                "backtest_analysis": { "type": "boolean" },
                "auto_tuning": { "type": "boolean" },
                "artifact_builder": { "type": "boolean" },
                "external_context": { "type": "boolean" },
                "memory": { "type": "boolean" }
              },
              "additionalProperties": false
            },
            "external_context": {
              "type": "object",
              "required": [
                "enabled",
                "whitelist_mode",
                "allowed_sources",
                "require_confirmation"
              ],
              "properties": {
                "enabled": { "type": "boolean" },
                "whitelist_mode": { "type": "string", "enum": ["strict", "advisory"] },
                "allowed_sources": {
                  "type": "array",
                  "items": { "type": "string" }
                },
                "require_confirmation": { "type": "boolean" }
              },
              "additionalProperties": false
            },
            "memory": {
              "type": "object",
              "required": [
                "mode",
                "retention_days",
                "allow_user_delete",
                "capture_user_preferences"
              ],
              "properties": {
                "mode": { "type": "string", "enum": ["disabled", "session_only", "user_scoped"] },
                "retention_days": { "type": "integer", "minimum": 0 },
                "allow_user_delete": { "type": "boolean" },
                "capture_user_preferences": { "type": "boolean" }
              },
              "additionalProperties": false
            },
            "apply_policy": {
              "type": "object",
              "required": [
                "require_confirmation",
                "allow_workspace_write",
                "allow_strategy_write",
                "allow_high_risk_actions"
              ],
              "properties": {
                "require_confirmation": { "type": "boolean" },
                "allow_workspace_write": { "type": "boolean" },
                "allow_strategy_write": { "type": "boolean" },
                "allow_high_risk_actions": { "type": "boolean" }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
